# Route /api/v1/parts/42 to /api/v1/parts/index.php
# Each endpoint directory has its own index.php
RewriteEngine On
RewriteBase /api/v1/

# If the request maps to an existing file, serve it directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Otherwise, route to the index.php in the deepest matching directory
# e.g. /api/v1/parts/42/moments → /api/v1/parts/index.php (with PATH_INFO)
RewriteRule ^(parts|tracks|workers|moments|oss|takes|marbles|rides)(/.*)?$ $1/index.php [L,QSA]
